Proceso calculoCirculo
	Definir r, ar, per, p, dia Como Real;
	Escribir "Bienvenido. Este programa sirve para calcular el area y perimetro de un circulo.";
	Escribir "Ingrese el radio de su circulo: ";
	Leer r;
	dia = r + r;
	ar = (pi * r)^ 2;
	pr = (pi * dia);
	Escribir "El area de tu circulo es: ", ar;
	Escribir "El perimetro de tu circulo es: ", pr;
	Escribir "El radio de tu circulo es: ", r;
	Escribir "Gracias por usar el programa.";
	
	
	
FinProceso
